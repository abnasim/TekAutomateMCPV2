      {
        "name": "channel",
        "type": "mnemonic",
        "required": true,
        "position": 0,
        "description": "Analog channel selector.",
        "mnemonicType": "channel",
        "validValues": {
          "type": "mnemonic_range",
          "pattern": "CH<x>",
          "examples": [
            "CH1",
            "CH2",
            "CH3",
            "CH4"
          ]
